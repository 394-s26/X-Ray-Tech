rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isTeamLead(uid) {
      let myTeamCode = get(/databases/$(database)/documents/users/$(request.auth.uid)).data.teamCode;
      return isSignedIn()
        && myTeamCode != null
        && get(/databases/$(database)/documents/teams/$(myTeamCode)).data.teamLead == request.auth.uid
        && (uid in get(/databases/$(database)/documents/teams/$(myTeamCode)).data.members
            || uid == get(/databases/$(database)/documents/teams/$(myTeamCode)).data.teamLead);
    }

    match /users/{uid} {
      allow read: if isSignedIn();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid)
                    || (isTeamLead(uid) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['teamCode', 'role']));
      allow delete: if isOwner(uid);

      // Mirror of per-license-cycle CE credits, written eagerly on every cert change.
      match /cycleCredits/{cycleId} {
        allow read: if isSignedIn();
        allow write: if isOwner(uid);
      }
    }

    match /usernames/{username} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow update: if false;
      allow delete: if isSignedIn() && resource.data.uid == request.auth.uid;
    }

    match /certificates/{certId} {
      // Support both ownerId (manual form) and uid (OCR upload flow).
      // Team leads can also read certificates belonging to their teammates so
      // the Team Management page can show real license progress.
      allow read: if isOwner(resource.data.ownerId)
                  || isOwner(resource.data.uid)
                  || isTeamLead(resource.data.ownerId)
                  || isTeamLead(resource.data.uid);
      allow create: if isOwner(request.resource.data.ownerId)
                    || (isOwner(request.resource.data.uid)
                        && request.resource.data.validated == 'pending');
      allow update: if (isOwner(resource.data.ownerId)
                        && request.resource.data.ownerId == resource.data.ownerId)
                    || (isOwner(resource.data.uid)
                        && request.resource.data.uid == resource.data.uid);
      allow delete: if isOwner(resource.data.ownerId) || isOwner(resource.data.uid);
    }

    match /scantrons/{scantronId} {
      allow read: if isOwner(resource.data.uid);
      allow create: if isOwner(request.resource.data.uid);
      allow update: if isOwner(resource.data.uid)
                    && request.resource.data.uid == resource.data.uid;
      allow delete: if isOwner(resource.data.uid);
    }

    match /teams/{teamId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.teamLead == request.auth.uid;
      allow update: if isOwner(resource.data.teamLead)
                    || (isSignedIn()
                        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members'])
                        && request.auth.uid in request.resource.data.members
                        && !(request.auth.uid in resource.data.members));
      allow delete: if isOwner(resource.data.teamLead);
    }

    // Default deny — any new collection must be added explicitly above.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
