# Gmail sender credentials for certificate-expiry emails.
# Copy this file to `.env` (same folder) and fill in real values.
# .env is gitignored — never commit real credentials.

# The Gmail address that sends the emails.
GMAIL_EMAIL=

# A Google App Password (16 chars) for that account — NOT the login password.
# Requires 2-Step Verification: https://myaccount.google.com/apppasswords
GMAIL_APP_PASSWORD=
