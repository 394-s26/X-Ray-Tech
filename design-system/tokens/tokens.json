{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "meta": {
    "name": "X-Ray Tech Design System",
    "version": "1.0.0",
    "description": "Design system for X-Ray Tech — a credentialing and license-progress platform for X-ray technologists and the managers who lead them.",
    "primaryColor": "#5B3FE4",
    "typeface": "Inter + Geist + JetBrains Mono",
    "baseUnit": 4
  },
  "color": {
    "brand": {
      "50":  { "value": "#F4F0FE", "type": "color" },
      "100": { "value": "#E5DDFC", "type": "color" },
      "200": { "value": "#C9B8F8", "type": "color" },
      "300": { "value": "#A78EF3", "type": "color" },
      "400": { "value": "#8366ED", "type": "color" },
      "500": { "value": "#6E50E9", "type": "color" },
      "600": { "value": "#5B3FE4", "type": "color", "description": "Primary brand color — CTAs, mark, emphasis" },
      "700": { "value": "#4A2FCC", "type": "color", "description": "Primary hover/pressed" },
      "800": { "value": "#3A23A8", "type": "color" },
      "900": { "value": "#1C0F5C", "type": "color" }
    },
    "ink-purple": {
      "value": "#4E2A84",
      "type": "color",
      "description": "Heritage royal purple — used for h1–h2 headings on paper, chart fills, dense data ink. Retains brand equity from the legacy palette."
    },
    "ink": {
      "100": { "value": "#F4F3F7", "type": "color" },
      "200": { "value": "#E5E3EC", "type": "color" },
      "300": { "value": "#C9C5D2", "type": "color" },
      "400": { "value": "#9A95A6", "type": "color" },
      "500": { "value": "#6C677A", "type": "color" },
      "600": { "value": "#4A4659", "type": "color" },
      "700": { "value": "#2D2A3D", "type": "color" },
      "900": { "value": "#0E0B1F", "type": "color", "description": "Primary text color — deep cool near-black with subtle violet undertone" }
    },
    "paper":     { "value": "#FFFFFF", "type": "color", "description": "Marketing page background" },
    "surface":   { "value": "#FAFAFC", "type": "color", "description": "Cards, modals, product UI canvas" },
    "line":      { "value": "#E5E3EC", "type": "color", "description": "Dividers on paper" },
    "line-soft": { "value": "#F0EEF5", "type": "color" },
    "success": {
      "100": { "value": "#E2F5EC", "type": "color" },
      "600": { "value": "#1F9D6B", "type": "color" }
    },
    "warn": {
      "100": { "value": "#FBF2DC", "type": "color" },
      "600": { "value": "#C08415", "type": "color" }
    },
    "danger": {
      "100": { "value": "#FAE4E2", "type": "color" },
      "600": { "value": "#C8382F", "type": "color" }
    },
    "info": {
      "100": { "value": "#E5DDFC", "type": "color" },
      "600": { "value": "#5B3FE4", "type": "color" }
    }
  },
  "font": {
    "family": {
      "display": { "value": "'Geist', 'Inter', ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif", "type": "fontFamily", "description": "Headings, hero copy, marketing display" },
      "sans":    { "value": "'Inter', ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif", "type": "fontFamily", "description": "Body, UI, paragraphs" },
      "mono":    { "value": "'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, monospace", "type": "fontFamily", "description": "Numeric data — license points, dates, cert IDs, counters" },
      "serif":   { "value": "ui-serif, Georgia, 'Times New Roman', serif", "type": "fontFamily", "description": "Reserved for long-form legal/contract PDFs only" }
    },
    "weight": {
      "regular":  { "value": 400, "type": "fontWeight" },
      "medium":   { "value": 500, "type": "fontWeight" },
      "semibold": { "value": 600, "type": "fontWeight" },
      "bold":     { "value": 700, "type": "fontWeight" }
    }
  },
  "size": {
    "display-xl": { "value": "72px", "type": "dimension", "lineHeight": "80px", "weight": 600, "tracking": "-0.02em", "family": "display" },
    "display-lg": { "value": "56px", "type": "dimension", "lineHeight": "64px", "weight": 600, "tracking": "-0.02em", "family": "display" },
    "h1":         { "value": "40px", "type": "dimension", "lineHeight": "48px", "weight": 600, "tracking": "-0.015em", "family": "display" },
    "h2":         { "value": "32px", "type": "dimension", "lineHeight": "40px", "weight": 600, "tracking": "-0.015em", "family": "display" },
    "h3":         { "value": "24px", "type": "dimension", "lineHeight": "32px", "weight": 600, "tracking": "-0.015em", "family": "display" },
    "h4":         { "value": "20px", "type": "dimension", "lineHeight": "28px", "weight": 600, "tracking": "-0.015em", "family": "sans" },
    "body-lg":    { "value": "18px", "type": "dimension", "lineHeight": "28px", "weight": 400, "family": "sans" },
    "body-md":    { "value": "16px", "type": "dimension", "lineHeight": "24px", "weight": 400, "family": "sans" },
    "body-sm":    { "value": "14px", "type": "dimension", "lineHeight": "20px", "weight": 400, "family": "sans" },
    "caption":    { "value": "12px", "type": "dimension", "lineHeight": "16px", "weight": 500, "family": "sans" },
    "overline":   { "value": "11px", "type": "dimension", "lineHeight": "16px", "weight": 600, "tracking": "+0.06em", "transform": "uppercase", "family": "sans" },
    "mono-xl":    { "value": "48px", "type": "dimension", "lineHeight": "52px", "weight": 600, "tracking": "-0.02em", "family": "mono", "description": "Big-number stat (license points, days-until-expiry)" },
    "mono-lg":    { "value": "24px", "type": "dimension", "lineHeight": "32px", "weight": 500, "family": "mono" },
    "mono-md":    { "value": "14px", "type": "dimension", "lineHeight": "20px", "weight": 400, "family": "mono", "description": "Cert IDs, dates in tables" },
    "mono-sm":    { "value": "12px", "type": "dimension", "lineHeight": "16px", "weight": 400, "family": "mono" }
  },
  "space": {
    "0":   { "value": "0px",   "type": "dimension" },
    "0_5": { "value": "2px",   "type": "dimension" },
    "1":   { "value": "4px",   "type": "dimension" },
    "1_5": { "value": "6px",   "type": "dimension" },
    "2":   { "value": "8px",   "type": "dimension" },
    "3":   { "value": "12px",  "type": "dimension" },
    "4":   { "value": "16px",  "type": "dimension" },
    "5":   { "value": "20px",  "type": "dimension" },
    "6":   { "value": "24px",  "type": "dimension" },
    "8":   { "value": "32px",  "type": "dimension" },
    "10":  { "value": "40px",  "type": "dimension" },
    "12":  { "value": "48px",  "type": "dimension" },
    "16":  { "value": "64px",  "type": "dimension" },
    "20":  { "value": "80px",  "type": "dimension" },
    "24":  { "value": "96px",  "type": "dimension" },
    "32":  { "value": "128px", "type": "dimension" },
    "40":  { "value": "160px", "type": "dimension" }
  },
  "radius": {
    "none": { "value": "0px",    "type": "dimension" },
    "xs":   { "value": "4px",    "type": "dimension" },
    "sm":   { "value": "6px",    "type": "dimension", "description": "Buttons, inputs (product UI)" },
    "md":   { "value": "8px",    "type": "dimension", "description": "Cards (dashboard standard)" },
    "lg":   { "value": "12px",   "type": "dimension", "description": "Images, modals" },
    "xl":   { "value": "20px",   "type": "dimension" },
    "full": { "value": "9999px", "type": "dimension", "description": "Pills, badges, marketing CTAs" }
  },
  "shadow": {
    "none": { "value": "none", "type": "shadow" },
    "xs":   { "value": "0 1px 2px rgba(14, 11, 31, 0.04)", "type": "shadow" },
    "sm":   { "value": "0 1px 3px rgba(14, 11, 31, 0.06), 0 1px 2px rgba(14, 11, 31, 0.04)", "type": "shadow" },
    "md":   { "value": "0 4px 12px rgba(14, 11, 31, 0.06), 0 2px 4px rgba(14, 11, 31, 0.04)", "type": "shadow" },
    "lg":   { "value": "0 12px 32px rgba(14, 11, 31, 0.08), 0 4px 8px rgba(14, 11, 31, 0.04)", "type": "shadow" },
    "xl":   { "value": "0 24px 48px rgba(14, 11, 31, 0.10), 0 8px 16px rgba(14, 11, 31, 0.06)", "type": "shadow" }
  },
  "motion": {
    "duration": {
      "xs": { "value": "80ms",  "type": "duration" },
      "sm": { "value": "160ms", "type": "duration" },
      "md": { "value": "240ms", "type": "duration" },
      "lg": { "value": "480ms", "type": "duration" },
      "xl": { "value": "720ms", "type": "duration" }
    },
    "ease": {
      "out":       { "value": "cubic-bezier(0.22, 1, 0.36, 1)", "type": "cubicBezier" },
      "in-out":    { "value": "cubic-bezier(0.4, 0, 0.2, 1)",   "type": "cubicBezier" },
      "standard":  { "value": "cubic-bezier(0.4, 0, 0.2, 1)",   "type": "cubicBezier" },
      "linear":    { "value": "linear",                         "type": "cubicBezier" }
    }
  },
  "breakpoint": {
    "sm": { "value": "640px",  "type": "dimension" },
    "md": { "value": "768px",  "type": "dimension" },
    "lg": { "value": "1024px", "type": "dimension" },
    "xl": { "value": "1280px", "type": "dimension" },
    "2xl":{ "value": "1536px", "type": "dimension" }
  },
  "container": {
    "max":            { "value": "1200px", "type": "dimension" },
    "reading":        { "value": "680px",  "type": "dimension" },
    "gutter-mobile":  { "value": "16px",   "type": "dimension" },
    "gutter-desktop": { "value": "24px",   "type": "dimension" }
  }
}
